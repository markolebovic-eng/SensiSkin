{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(mkdir *)",
      "Bash(date)",
      "Bash(date *)",
      "Bash(python scripts/generate_pdf_report.py *)",
      "Bash(python3 scripts/generate_pdf_report.py *)"
    ],
    "ask": [
      "Bash(git add)",
      "Bash(git add *)",
      "Bash(git commit)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git pull)",
      "Bash(git pull *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Read(.env)",
      "Read(.env.*)"
    ],
    "defaultMode": "default"
  }
}